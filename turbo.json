{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "db:generate:full": {
      "cache": false,
      "outputs": ["packages/database/generated/full-client/**"]
    },
    "db:generate:local": {
      "cache": false,
      "outputs": ["packages/database/generated/local-client/**"]
    },
    "db:generate:local-sql": {
      "cache": false,
      "outputs": ["packages/database/prisma/generated/local-schema.sql"]
    },
    "build": {
      "dependsOn": ["^build", "db:generate:full"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["db:generate:full"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
