Ref: FiscalDocument.saleId > Sale.id
Ref: FiscalDocument.purchaseReceptionId > PurchaseReception.id
Ref: FiscalDocument.clientReturnId > ClientReturn.id
Ref: FiscalDocument.resolutionId > FiscalResolution.id
Ref: FiscalDocument.allocationId > FiscalResolutionAllocation.id
