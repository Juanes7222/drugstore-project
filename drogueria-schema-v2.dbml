Ref: PurchaseReceptionItem.purchaseOrderItemId > PurchaseOrderItem.id
Ref: PurchaseReceptionItem.lotId > Lot.id
Ref: PurchaseReceptionItem.taxSchemeId > TaxScheme.id

Ref: SupplierReturn.supplierId > Supplier.id
Ref: SupplierReturn.purchaseReceptionId > PurchaseReception.id
Ref: SupplierReturn.createdById > User.id [delete: no action]
Ref: SupplierReturn.annulledById > User.id [delete: no action]
Ref: SupplierReturnItem.supplierReturnId > SupplierReturn.id
Ref: SupplierReturnItem.productId > Product.id
Ref: SupplierReturnItem.lotId > Lot.id

// Sales POS
Ref: Sale.cashShiftId > CashShift.id
Ref: Sale.workstationId > Workstation.id
Ref: Sale.userId > User.id [delete: no action]
Ref: Sale.clientId > Client.id
Ref: Sale.annulledById > User.id [delete: no action]
Ref: Sale.sourceWorkstationId > Workstation.id
Ref: Sale.clientClassificationIdSnapshot > ClientClassification.id

Ref: SaleItem.saleId > Sale.id
Ref: SaleItem.productId > Product.id
