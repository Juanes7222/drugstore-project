{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "backend",
  "formatter": false,
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "instructions": [
    "AGENTS.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".turbo/**",
      "coverage/**",
      ".next/**",
      "out/**",
      "*.log",
      "**/*.tsbuildinfo",
      "**/generated/**",
      "apps/server/prisma/generated/**",
      ".git/**"
    ]
  }
}