{
  "name": "@pharmacy/server",
  "version": "0.1.0",
  "type": "module",
  "description": "NestJS backend server for pharmacy POS system",
  "main": "dist/apps/server/src/main.js",
  "scripts": {
    "build": "nest build",
    "start": "tsx dist/apps/server/src/main.js",
    "start:watch": "concurrently -k -n \"tsc,node\" -c \"blue,green\" \"nest build --watch\" \"nodemon --watch dist/apps/server/src -e js --delay 2 --exec tsx dist/apps/server/src/main.js\"",
    "dev": "concurrently -k -n \"tsc,node\" -c \"blue,green\" \"nest build --watch\" \"nodemon --watch dist/apps/server/src -e js --delay 2 --exec tsx dist/apps/server/src/main.js\"",
    "db:push": "npx prisma db push --schema ../../packages/database/prisma/schema --config ../../packages/database/prisma.full.config.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma db push --force-reset --schema ../../packages/database/prisma/schema --config ../../packages/database/prisma.full.config.ts && npx tsx prisma/seed.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:cov": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.ts --forceExit --detectOpenHandles",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@pharmacy/database": "workspace:*",
    "@pharmacy/shared-validation": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.3",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
