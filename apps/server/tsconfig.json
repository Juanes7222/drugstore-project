{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": "./",
    "isolatedModules": false,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./src/*"],
      "@prisma/client": ["../../node_modules/.prisma/client"],
      "@pharmacy/shared-types": ["../../packages/shared-types/src"],
      "@pharmacy/shared-validation": ["../../packages/shared-validation/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
