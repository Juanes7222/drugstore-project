{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": "./",
    "isolatedModules": false,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@pharmacy/shared-types": ["../../packages/shared-types/src"],
      "@pharmacy/shared-validation": ["../../packages/shared-validation/src"],
      "@pharmacy/database": ["../../packages/database/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "generated", "**/*.spec.ts", "**/*.test.ts"]
}
