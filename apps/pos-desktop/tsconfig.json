{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@infra/*": ["./src/infrastructure/*"],
      "@pharmacy/database": ["../../packages/database/src/index.ts"],
      "@pharmacy/database/*": ["../../packages/database/src/*"],
      "@pharmacy/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@pharmacy/shared-validation": ["../../packages/shared-validation/src/index.ts"]
    }
  },
  "include": ["src", "vitest.setup.ts"],
  "exclude": ["node_modules", "dist", "src-tauri"],
  "references": [
    { "path": "./tsconfig.node.json" }
  ]
}
