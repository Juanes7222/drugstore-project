# ---------------------------------------------------------------------------
# POS Desktop — Configuration
# ---------------------------------------------------------------------------
# All env vars are read from a single source: src/infrastructure/config.ts.
# Never access import.meta.env directly outside that file.
# ---------------------------------------------------------------------------

# API base URL for the NestJS backend (apps/server).
# If unset, config.ts falls back to "http://localhost:3000" for local dev.
# Production builds MUST set this via the build pipeline or runtime .env.
VITE_API_BASE_URL=

# Set to "1" to render the PGlite database proof-of-concept component
# instead of the regular POS UI (foundation validation only).
# VITE_DB_PROOF=1

# ---------------------------------------------------------------------------
# Fiscal / DIAN contingency configuration
# ---------------------------------------------------------------------------
# Workstation-local contingency technical key. MUST be a unique UUID per
# terminal. The default placeholder prevents sale confirmation until set.
# VITE_CONTINGENCY_TECH_KEY=

# Time zone for invoice timestamps and CUFE calculation (defaults to America/Bogota).
# VITE_FISCAL_TIME_ZONE=America/Bogota

# Contingency transmission window in hours (defaults to 48).
# VITE_CONTINGENCY_TRANSMISSION_WINDOW_HOURS=48

# Network debounce for automatic contingency transitions in milliseconds.
# VITE_CONTINGENCY_ENTER_DEBOUNCE_MS=30000
# VITE_CONTINGENCY_EXIT_DEBOUNCE_MS=10000
