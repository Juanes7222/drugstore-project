# API base URL for the POS renderer.
# Set this to the running NestJS server (e.g. http://localhost:3000).
# If unset, the Sales/Cart screen falls back to the mock catalog service.
VITE_API_BASE_URL=

# Set to "1" to render the PGlite database proof-of-concept component instead
# of the regular POS UI (used during foundation validation only).
# VITE_DB_PROOF=1
