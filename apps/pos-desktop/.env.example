# ---------------------------------------------------------------------------
# POS Desktop — Configuration
# ---------------------------------------------------------------------------
# All env vars are read from a single source: src/infrastructure/config.ts.
# Never access import.meta.env directly outside that file.
# ---------------------------------------------------------------------------

# API base URL for the NestJS backend (apps/server).
# If unset, config.ts falls back to "http://localhost:3000" for local dev.
# Production builds MUST set this via the build pipeline or runtime .env.
VITE_API_BASE_URL=

# Set to "1" to render the PGlite database proof-of-concept component
# instead of the regular POS UI (foundation validation only).
# VITE_DB_PROOF=1
