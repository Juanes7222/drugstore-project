DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy-system
REDIS_URL=redis://localhost:6379

# Certificate base directory for FileSystemSecretReaderAdapter.
# "file:"-prefixed credential references are resolved relative to this path.
CERTIFICATE_BASE_DIR=./certs

# Private-key password for all .p12 certificates resolved through
# FileSystemSecretReaderAdapter. In production this must be stored
# in a proper secret manager, not in an environment variable.
DIAN_CERTIFICATE_PASSWORD=change-me
