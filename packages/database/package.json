{
  "name": "@pharmacy/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Prisma schema, generated client, and type re-exports for all apps",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./full": {
      "types": "./dist/src/full.d.ts",
      "import": "./dist/src/full.js"
    },
    "./local": {
      "types": "./dist/src/local.d.ts",
      "import": "./dist/src/local.js"
    },
    "./local-schema": {
      "types": "./dist/src/local-schema.d.ts",
      "import": "./dist/src/local-schema.js"
    }
  },
  "scripts": {
    "db:generate:full": "node scripts/assemble-schema.mjs full && prisma generate --config prisma.full.config.ts",
    "db:generate:local": "node scripts/assemble-schema.mjs local && prisma generate --config prisma.local.config.ts",
    "db:generate:local-sql": "node scripts/assemble-schema.mjs local && node scripts/generate-local-sql.mjs",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
