// LOCAL-ONLY schema fragment — Fiscal documents and contingency management
// for apps/pos-desktop.
//
// These models are intentionally not propagated to the server schema. They
// exist only on the terminal to support offline Colombian DIAN contingency
// invoicing: provisional documents are generated locally while offline, then
// queued for DIAN transmission when connectivity returns.

enum InvoiceType {
  ELECTRONIC_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
  SUPPORT_DOCUMENT
  CONTINGENCY_CANCELLATION
}

enum InvoiceStatus {
  CONTINGENCY_PENDING_TRANSMISSION
  TRANSMITTED_AUTHORIZED
  TRANSMITTED_REJECTED
  EXPIRED_CONTINGENCY
  CANCELLED
}

enum ContingencyTrigger {
  NETWORK_LOST
  MANUAL_OVERRIDE
  SERVER_UNREACHABLE
}

model Invoice {
  id                String        @id
  saleId            String
  workstationId     String
  invoiceType       InvoiceType
  invoiceNumber     String
  contingencyNumber String?
  status            InvoiceStatus @default(CONTINGENCY_PENDING_TRANSMISSION)
  cufeProvisional   String
  cufeOfficial      String?
  issuedAt          DateTime
  transmittedAt     DateTime?
  expiresAt         DateTime
  fiscalXml         String?       @db.Text
  fiscalPdfPath     String?
  relatedInvoiceId  String?
  relatedInvoice    Invoice?      @relation("RelatedInvoice", fields: [relatedInvoiceId], references: [id], onDelete: Restrict)
  relatedTo         Invoice[]     @relation("RelatedInvoice")
  contingencyEventId String?
  techKeySnapshot   String
  fullData          Json

  @@unique([invoiceNumber, workstationId])
  @@unique([contingencyNumber, workstationId])
  @@index([saleId])
  @@index([workstationId, status])
  @@index([status, expiresAt])
  @@index([contingencyEventId])
}

model ContingencyEvent {
  id                   String            @id
  startedAt            DateTime
  endedAt              DateTime?
  workstationId        String
  trigger              ContingencyTrigger
  triggerReason        String
  invoicesGenerated    Int               @default(0)
  invoicesTransmitted  Int               @default(0)
  invoicesExpired      Int               @default(0)
  notifiedDian         Boolean           @default(false)

  @@index([workstationId, endedAt])
  @@index([startedAt])
}

enum InvoiceAdjustmentType {
  PAYMENT_METHOD_CHANGE
  PAYMENT_SPLIT_CHANGE
  INTERNAL_NOTE
  CONTACT_UPDATE
  DELIVERY_INFO
  TAG_ADD
  TAG_REMOVE
  CUSTOM_FIELD_SET
  CUSTOM_FIELD_CLEAR
  REVERSAL
}

/// Local-only operational annotation layer alongside the immutable fiscal
/// Invoice. These adjustments never sync to the server and never affect
/// what DIAN sees — they only affect how the local POS interprets the
/// invoice for operational purposes (cash shift reconciliation, internal
/// reports, customer-facing reprints).
model InvoiceLocalAdjustment {
  id                        String                   @id
  invoiceId                 String
  createdAt                 DateTime
  createdByUserId           String
  /// Denormalized actor name for audit trail resilience — the User table is
  /// server-only and may not be queryable locally during an audit.
  createdByUserName         String
  adjustmentType            InvoiceAdjustmentType
  /// The previous value being changed (null for additions like TAG_ADD).
  previousValue             Json?
  /// The new value being applied (null for REVERSAL and TAG_REMOVE).
  newValue                  Json?
  /// Required reason for the adjustment (min 10 chars, validated at service
  /// level).
  reason                    String
  /// Optimistic concurrency version: the 1-based index of this adjustment
  /// within the invoice's non-reversed chain. Unique per invoice so concurrent
  /// writes to the same invoice with the same version are rejected.
  version                   Int
  /// When adjustmentType = REVERSAL, this FK points to the original adjustment
  /// being reversed.
  reversalOfAdjustmentId    String?
  /// When this adjustment is later reversed, this FK is populated with the id
  /// of the reversal adjustment, enabling bidirectional chain traversal.
  replacedByAdjustmentId    String?

  @@unique([invoiceId, version])
  @@index([invoiceId, createdAt])
  @@index([createdByUserId])
  @@index([adjustmentType])
  @@index([reversalOfAdjustmentId])
  @@index([replacedByAdjustmentId])
}

model FiscalCounter {
  id                     String      @id
  workstationId          String      @unique
  currentRegularNumber   BigInt      @default(0)
  currentContingencyNumber BigInt    @default(0)
  resolutionPrefix       String      @default("FE")
  contingencyPrefix      String      @default("CONT")
  paddingLength          Int         @default(8)
  authorizedStart        BigInt      @default(1)
  authorizedEnd          BigInt      @default(99999999)
  updatedAt              DateTime    @updatedAt
}
