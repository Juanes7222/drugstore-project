// Local-only schema fragment — included only in the local build.
// Tracks POS events that happen offline: cash-shift ops, sales, auth,
// sync, inventory adjustments, etc.
//
// The server has its own AuditLog model with User/Workstation/UserSession
// relations. This is the offline counterpart: no relations, just indexed
// flat rows.  Events are written by each domain service (cash-shift, sales,
// auth, etc.) at the same time the operation executes locally.
//
// This file is generated by scripts/split-schema.mjs.

model LocalAuditLog {
  id            String   @id
  action        String   // e.g. "CASH_SHIFT_OPENED", "SALE_CONFIRMED"
  category      String   // "cash_shift" | "sale" | "client" | "auth"
                         // | "sync" | "inventory" | "prescription" | "fiscal"
  entityType    String?
  entityId      String?
  entityName    String?
  details       String?  @db.Text  // JSON — event-specific payload
  userId        String?
  userRole      String?
  workstationId String?
  sessionId     String?
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([category, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
}
