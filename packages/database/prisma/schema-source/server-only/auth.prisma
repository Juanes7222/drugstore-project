// Server-only schema fragment — only included in the full build.
// Enhanced identity & auth models supporting four user types, multi-session,
// step-up auth, and audit logging.

model User {
  id                        String    @id
  subscriptionId            String?
  role                      RoleType
  email                     String?   @unique
  username                  String?
  fullName                  String
  displayName               String?
  avatarUrl                 String?
  avatarColor               String?
  authMethod                AuthMethod @default(PASSWORD_ONLY)
  passwordHash              String?
  passwordAlgorithm         String?
  pinHash                   String?
  totpSecretEncrypted       String?   @db.Text
  totpEnabled               Boolean   @default(false)
  backupCodesHash           String?
  passwordChangedAt         DateTime?
  lastPasswordChangeAt      DateTime?
  passwordMustChangeNextLogin Boolean @default(false)
  status                    UserStatus @default(PENDING_SETUP)
  isActive                  Boolean   @default(true)
  failedLoginAttempts       Int       @default(0)
  lockedUntil               DateTime?
  emailVerifiedAt           DateTime?
  phoneVerifiedAt           DateTime?
  lastLoginAt               DateTime?
  lastLoginWorkstationId    String?
  mustChangePassword        Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  createdById               String?
  createdByUser             User?     @relation("CreatedByUser", fields: [createdById], references: [id], onDelete: NoAction)
  createdUsers              User[]    @relation("CreatedByUser")
  sessions                  UserSession[]
  revokedSessions           UserSession[] @relation("RevokedByUser")
  locationAccess            UserLocationAccess[]
  stepUpRequests            StepUpRequest[] @relation("RequestingUser")
  approvedStepUps           StepUpRequest[] @relation("ApprovingUser")
  deniedStepUps             StepUpRequest[] @relation("DenyingUser")
  loginAttempts             LoginAttempt[]
  inventoryAdjustmentDocuments InventoryAdjustmentDocument[] @relation("CreatedByUser")
  approvedAdjustmentDocuments InventoryAdjustmentDocument[] @relation("ApprovedByUser")
  rejectedAdjustmentDocuments InventoryAdjustmentDocument[] @relation("RejectedByUser")
  annulledAdjustmentDocuments InventoryAdjustmentDocument[] @relation("AnnulledByUser")
  autoExpirationJobs        AutoExpirationJob[]
  physicalCounts            PhysicalCount[] @relation("StartedByUser")
  approvedPhysicalCounts    PhysicalCount[] @relation("ApprovedByUser")
  suppliers                 Supplier[]
  purchaseOrders            PurchaseOrder[]
  confirmedPurchaseOrders   PurchaseOrder[] @relation("ConfirmedPurchaseOrder")
  annulledPurchaseOrders    PurchaseOrder[] @relation("AnnulledPurchaseOrder")
  purchaseReceptions        PurchaseReception[]
  annulledPurchaseReceptions PurchaseReception[] @relation("AnnulledPurchaseReception")
  supplierReturns           SupplierReturn[]
  annulledSupplierReturns   SupplierReturn[] @relation("AnnulledSupplierReturn")
  prescriptions             Prescription[]
  clientReturns             ClientReturn[]
  annulledClientReturns     ClientReturn[] @relation("AnnulledByUser")
  fiscalIssuerConfigs       FiscalIssuerConfig[]
  techProviderConfigs       TechProviderConfig[]
  resolutionAllocations     FiscalResolutionAllocation[]
  systemConfigs             SystemConfig[]
  auditLogs                 AuditLog[]

  @@index([role])
  @@index([subscriptionId, username])
  @@index([subscriptionId, role])
  @@index([status])
}

model UserSession {
  id                      String            @id
  userId                  String
  user                    User              @relation(fields: [userId], references: [id], onDelete: NoAction)
  workstationId           String
  workstation             Workstation       @relation(fields: [workstationId], references: [id])
  workstationFingerprint  String?
  deviceInfo              String?
  tokenHash               String            @unique
  refreshTokenHash        String?
  accessTokenId           String?
  refreshTokenId          String?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  issuedAt                DateTime
  lastActivityAt            DateTime
  expiresAt               DateTime
  status                  SessionStatus     @default(ACTIVE)
  revokedAt               DateTime?
  revokedReason           SessionRevocationReason?
  revokedByUserId         String?
  revokedByUser           User?             @relation("RevokedByUser", fields: [revokedByUserId], references: [id], onDelete: NoAction)
  ipAddress               String?
  userAgent               String?
  geoCountry              String?
  geoCity                 String?
  auditLogs               AuditLog[]

  @@index([userId, status])
  @@index([expiresAt])
  @@index([tokenHash])
}

model Workstation {
  id            String    @id
  name          String    @unique
  code          String    @unique
  macAddress    String?
  serialNumber  String?
  isActive      Boolean   @default(true)
  registeredAt  DateTime
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      UserSession[]
  auditLogs     AuditLog[]
  clientReturns ClientReturn[]
  fiscalResolutions           FiscalResolution[]
  resolutionAllocations       FiscalResolutionAllocation[]
}

/// Grants a user access to a specific location (for multi-location plans).
/// OWNERs have implicit access to all locations in their subscription.
/// MANAGERs are restricted to specific locations through this relation.
model UserLocationAccess {
  id          String    @id
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: NoAction)
  locationId  String
  createdAt   DateTime  @default(now())

  @@unique([userId, locationId])
  @@index([locationId])
}

/// Records a step-up authorization request for sensitive operations.
model StepUpRequest {
  id                String        @id
  operationType     String
  operationId       String?
  requestingUserId  String
  requestingUser    User          @relation("RequestingUser", fields: [requestingUserId], references: [id], onDelete: NoAction)
  workstationId     String
  requiredRole      RoleType
  status            StepUpStatus  @default(PENDING)
  method            String?
  approvedByUserId  String?
  approvedByUser    User?         @relation("ApprovingUser", fields: [approvedByUserId], references: [id], onDelete: NoAction)
  deniedByUserId    String?
  deniedByUser      User?         @relation("DenyingUser", fields: [deniedByUserId], references: [id], onDelete: NoAction)
  denialReason      String?
  approvalToken     String?       @unique
  oneTimeCode       String?
  expiresAt         DateTime
  createdAt         DateTime      @default(now())

  @@index([requestingUserId, status])
  @@index([workstationId, status])
  @@index([status, expiresAt])
}

/// Records every login attempt (success or failure) for audit and anomaly detection.
model LoginAttempt {
  id              String    @id
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: NoAction)
  identifier      String
  sessionType     String
  workstationId   String?
  ipAddress       String?
  success         Boolean
  failureReason   String?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([identifier, createdAt])
  @@index([createdAt])
}
