model PurchaseReception {
  id                    String    @id
  sequentialNumber      Int       @unique
  state                 PurchaseReceptionState @default(DRAFT)
  receivedAt            DateTime?
  createdAt             DateTime  @default(now())
  createdById           String
  createdByUser         User      @relation(fields: [createdById], references: [id], onDelete: NoAction)
  updatedAt             DateTime  @updatedAt
  notes                 String?
  subtotal              Decimal   @db.Decimal(15, 2) @default(0)
  totalTax              Decimal   @db.Decimal(15, 2) @default(0)
  totalAmount           Decimal   @db.Decimal(15, 2) @default(0)
  annulledAt            DateTime?
  annulledById          String?
  annulledByUser        User?     @relation("AnnulledPurchaseReception", fields: [annulledById], references: [id], onDelete: NoAction)
  annulmentReason       String?
  supplierId            String
  supplier              Supplier  @relation(fields: [supplierId], references: [id])
  purchaseOrderId       String?
  purchaseOrder         PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  items                 PurchaseReceptionItem[]
  fiscalDocuments       FiscalDocument[]
  supplierReturns       SupplierReturn[]

  @@index([supplierId, receivedAt])
  @@index([receivedAt])
  @@index([state])
}

model PurchaseReceptionItem {
  id                    String    @id
  purchaseReceptionId   String
  purchaseReception     PurchaseReception @relation(fields: [purchaseReceptionId], references: [id])
  productId             String
  purchaseOrderItemId   String?
  purchaseOrderItem     PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  lotId                 String?
  receivedQuantity      Int
  lotNumber             String?
  expirationDate        DateTime?
  realUnitCost          Decimal   @db.Decimal(15, 2)
  taxSchemeId           String
  taxRate               Decimal   @db.Decimal(6, 4) @default(0)
  taxAmount             Decimal   @db.Decimal(15, 2) @default(0)
  discountAmount        Decimal   @db.Decimal(15, 2) @default(0)
  subtotal              Decimal   @db.Decimal(15, 2) @default(0)
  total                 Decimal   @db.Decimal(15, 2) @default(0)

  @@index([purchaseReceptionId, productId])
}
