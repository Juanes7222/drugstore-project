model AuditLog {
  id                String    @id
  action            AuditAction
  module            SystemModule
  entityType        String
  entityId          String
  entityName        String?
  oldValues         Json?
  newValues         Json?
  details           String?   @db.Text
  userId            String?
  user              User?     @relation(fields: [userId], references: [id], onDelete: NoAction)
  userRole          String?
  workstationId     String?
  workstation       Workstation? @relation(fields: [workstationId], references: [id], onDelete: NoAction)
  sessionId         String?
  session           UserSession? @relation(fields: [sessionId], references: [id], onDelete: NoAction)
  correlationId     String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  @@index([createdAt, module])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([correlationId])
}
