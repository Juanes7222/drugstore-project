// Server-only schema fragment — only included in the full build.
// This file is generated by scripts/split-schema.mjs.

model Supplier {
  id                    String    @id
  identificationType    SupplierIdentificationType
  identificationNumber  String
  businessName          String
  contactName           String?
  phone                 String?
  email                 String?
  address               String?
  city                  String?
  country               String    @default("CO")
  paymentTermsDays      Int       @default(0)
  creditLimit           Decimal   @db.Decimal(15, 2) @default(0)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdById           String
  createdByUser         User      @relation(fields: [createdById], references: [id], onDelete: NoAction)
  purchaseOrders        PurchaseOrder[]
  purchaseReceptions    PurchaseReception[]
  supplierReturns       SupplierReturn[]

  @@unique([identificationType, identificationNumber])
  @@index([businessName])
}
