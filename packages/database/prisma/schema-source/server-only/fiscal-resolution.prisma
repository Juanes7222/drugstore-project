model FiscalResolution {
  id                    String    @id
  resolutionNumber      String    @unique
  documentType          FiscalDocumentType
  prefix                String
  rangeFrom             Int
  rangeTo               Int
  validFrom             DateTime
  validTo               DateTime
  state                 ResolutionState @default(ACTIVE)
  currentConsecutive    Int       @default(0)
  workstationId         String?
  workstation           Workstation? @relation(fields: [workstationId], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  allocations           FiscalResolutionAllocation[]
  fiscalDocuments       FiscalDocument[]

  @@index([documentType, prefix])
  @@index([workstationId, documentType, state])
}

model FiscalResolutionAllocation {
  id                    String    @id
  resolutionId          String
  resolution            FiscalResolution @relation(fields: [resolutionId], references: [id])
  workstationId         String
  workstation           Workstation @relation(fields: [workstationId], references: [id])
  rangeFrom             Int
  rangeTo               Int
  currentConsecutive    Int       @default(0)
  allocatedAt           DateTime
  allocatedByUserId     String
  allocatedByUser       User      @relation(fields: [allocatedByUserId], references: [id], onDelete: NoAction)
  exhaustedAt           DateTime?
  fiscalDocuments       FiscalDocument[]

  @@index([workstationId, resolutionId])
}
