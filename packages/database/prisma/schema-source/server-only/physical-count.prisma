model PhysicalCount {
  id                String    @id
  sequentialNumber  Int       @unique
  state             PhysicalCountState @default(OPEN)
  startedAt         DateTime
  startedByUserId   String
  startedByUser     User      @relation("StartedByUser", fields: [startedByUserId], references: [id], onDelete: NoAction)
  finishedAt        DateTime?
  approvedAt        DateTime?
  approvedByUserId  String?
  approvedByUser    User?     @relation("ApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: NoAction)
  appliedAt         DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  adjustmentDocuments InventoryAdjustmentDocument[]

  @@index([state])
  @@index([startedAt])
}
