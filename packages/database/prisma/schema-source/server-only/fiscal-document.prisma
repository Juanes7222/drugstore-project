model FiscalDocument {
  id                    String    @id
  documentType          FiscalDocumentType
  consecutiveNumber     Int
  fullNumber            String    @unique
  issueDate             DateTime
  cufeCude              String    @unique
  cufeCudeAlgorithm     String    @default("SHA-384")
  xmlPayload            String?   @db.Text
  signedXml             String?   @db.Text
  xmlHash               String?
  fiscalState           FiscalDocumentState @default(PENDING_GENERATION)
  ptResponseCode        String?
  ptResponseMessage     String?   @db.Text
  lastRetryAt           DateTime?
  contingencyReason     String?
  retryCount            Int       @default(0)
  subtotal              Decimal   @db.Decimal(15, 2) @default(0)
  totalTax              Decimal   @db.Decimal(15, 2) @default(0)
  totalAmount           Decimal   @db.Decimal(15, 2) @default(0)
  issuerNitSnapshot     String
  receiverNitSnapshot   String?
  receiverNameSnapshot  String?
  receiverType          String?
  saleId                String?
  purchaseReceptionId   String?
  // purchaseReceptionId is kept as scalar — PurchaseReception is now shared
  clientReturnId        String? @unique
  clientReturn          ClientReturn? @relation("CreditNote")
  resolutionId          String
  resolution            FiscalResolution @relation(fields: [resolutionId], references: [id])
  allocationId          String?
  allocation            FiscalResolutionAllocation? @relation(fields: [allocationId], references: [id])
  referenceDocumentId   String?
  referenceDocument     FiscalDocument? @relation("FiscalDocumentReference", fields: [referenceDocumentId], references: [id])
  referencedDocuments   FiscalDocument[] @relation("FiscalDocumentReference")
  validUntil            DateTime?
  archivedAt            DateTime?
  xmlStorageKey         String?
  xmlStorageBackend     String?
  retentionExpiresAt    DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([consecutiveNumber, resolutionId], name: "ux_fiscal_doc_res_consecutive")
  @@index([fiscalState])
  @@index([fiscalState, lastRetryAt])
  @@index([saleId])
  @@index([purchaseReceptionId])
  @@index([clientReturnId])
  @@index([issueDate])
  @@index([archivedAt])
  @@index([retentionExpiresAt])
}
