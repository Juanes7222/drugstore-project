model FiscalIssuerConfig {
  id                    String    @id
  nit                   String    @unique
  verificationDigit     String
  businessName          String
  commercialName        String?
  organizationType      String
  taxRegime             String
  taxResponsibilities   String?
  address               String
  municipality          String
  department            String
  postalCode            String?
  phone                 String?
  email                 String?
  logoUrl               String?
  updatedAt             DateTime  @updatedAt
  updatedById           String?
  updatedByUser         User?     @relation(fields: [updatedById], references: [id], onDelete: NoAction)
}

model TechProviderConfig {
  id                    String    @id
  endpointUrl           String
  environment           String
  timeoutSeconds        Int       @default(30)
  credentialReference   String?
  updatedAt             DateTime  @updatedAt
  updatedById           String?
  updatedByUser         User?     @relation(fields: [updatedById], references: [id], onDelete: NoAction)
}
