// Shared schema fragment — included in both full and local builds.

model PurchaseOrder {
  id                    String    @id
  sequentialNumber      Int       @unique
  state                 PurchaseOrderState @default(DRAFT)
  expectedDeliveryDate  DateTime?
  subtotal              Decimal   @db.Decimal(15, 2) @default(0)
  totalTax              Decimal   @db.Decimal(15, 2) @default(0)
  totalAmount           Decimal   @db.Decimal(15, 2) @default(0)
  notes                 String?
  createdAt             DateTime  @default(now())
  createdById           String
  confirmedAt           DateTime?
  confirmedById         String?
  annulledAt            DateTime?
  annulledById          String?
  annulmentReason       String?
  supplierId            String
  supplier              Supplier  @relation(fields: [supplierId], references: [id])
  items                 PurchaseOrderItem[]
  purchaseReceptions    PurchaseReception[]

  @@index([supplierId, state])
  @@index([state])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id                    String    @id
  purchaseOrderId       String
  purchaseOrder         PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId             String
  requestedQuantity     Int       @default(0)
  receivedQuantity      Int       @default(0)
  pendingQuantity       Int       @default(0)
  expectedUnitCost      Decimal   @db.Decimal(15, 2) @default(0)
  receptionItems        PurchaseReceptionItem[]

  @@index([purchaseOrderId, productId])
}
