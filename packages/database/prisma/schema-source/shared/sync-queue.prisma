// Shared schema fragment — included in both full and local builds.
// This file is generated by scripts/split-schema.mjs.

model SyncQueue {
  id                    String    @id
  operationUuid         String    @unique
  operationType         SyncOperationType
  payload               String    @db.Text
  payloadHash           String
  payloadSize           Int
  versionSchema         Int       @default(1)
  status                SyncStatus @default(PENDING)
  retryCount            Int       @default(0)
  lastErrorMessage      String?   @db.Text
  nextRetryAt           DateTime?
  sourceWorkstationId   String
  sourceCreatedAt       DateTime
  clientSequence        BigInt
  receivedAt            DateTime?
  processedAt           DateTime?
  operationSource       SyncSource @default(DIRECT)
  correlationId         String?
  workstationId         String?

  @@index([status, nextRetryAt])
  @@index([sourceWorkstationId, clientSequence])
  @@index([operationType, status])
  @@index([correlationId])
}
