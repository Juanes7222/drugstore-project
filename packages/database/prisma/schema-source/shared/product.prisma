// Shared schema fragment — included in both full and local builds.
// This file is generated by scripts/split-schema.mjs.

model Product {
  id                    String    @id
  internalCode          String    @unique
  commercialName        String
  genericName           String
  activePrinciple       String
  concentration         String?
  concentrationUnit     String?
  laboratory            String
  saleType              SaleType
  minimumStock          Int       @default(0)
  isActive              Boolean   @default(true)
  discontinuationReason String?
  invimaRegistry        String?
  atcCode               String?
  therapeuticIndication String?
  storageConditions     String?
  internalNotes         String?
  categoryId            String?
  category              Category? @relation(fields: [categoryId], references: [id])
  pharmaceuticalFormId  String?
  pharmaceuticalForm    PharmaceuticalForm? @relation(fields: [pharmaceuticalFormId], references: [id])
  currentPriceId        String?
  currentTaxHistoryId   String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdById           String
  priceHistories        ProductPriceHistory[]
  taxHistories          ProductTaxHistory[]
  barcodes              ProductBarcode[]
  lots                  Lot[]
  saleItems             SaleItem[]

  @@index([commercialName])
  @@index([genericName])
  @@index([activePrinciple])
  @@index([isActive])
  @@index([categoryId, isActive])
  @@index([invimaRegistry])
}
