model ProductPriceHistory {
  id                    String    @id
  productId             String
  product               Product   @relation(fields: [productId], references: [id])
  previousPriceHistoryId String?
  previousPriceHistory  ProductPriceHistory? @relation("PriceHistoryChain", fields: [previousPriceHistoryId], references: [id])
  nextPriceHistories    ProductPriceHistory[] @relation("PriceHistoryChain")
  price                 Decimal   @db.Decimal(15, 2)
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  changedById           String
  changedAt             DateTime
  changeReason          String?

  @@index([productId])
  @@index([productId, effectiveFrom])
}
