// Shared schema fragment — included in both full and local builds.
// This file is generated by scripts/split-schema.mjs.

model InventoryMovement {
  id                    String    @id
  movementType          MovementType
  quantity              Int
  previousStock         Int
  resultingStock        Int
  createdById           String
  createdAt             DateTime
  lotId                 String
  lot                   Lot       @relation(fields: [lotId], references: [id])
  adjustmentDocumentId  String?
  autoExpirationJobId   String?
  reason                String?
  approvedByUserId      String?
  purchaseReceptionId   String?
  saleId                String?
  sale                  Sale? @relation(fields: [saleId], references: [id])
  supplierReturnId      String?
  clientReturnId        String?

  @@index([lotId])
  @@index([lotId, createdAt])
  @@index([createdAt])
  @@index([movementType, createdAt])
  @@index([adjustmentDocumentId])
}
