{
  "name": "pharmacy-system",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first pharmacy management system (Droguería) for the Colombian regulatory context",
  "keywords": [
    "pharmacy",
    "pos",
    "point-of-sale",
    "drogueria",
    "dian",
    "fiscal",
    "colombia",
    "offline-first",
    "monorepo"
  ],
  "license": "Proprietary",
  "author": "Development Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/pharmacy-system.git"
  },
  "homepage": "https://pharmacy-system.local",
  "bugs": {
    "url": "https://github.com/your-org/pharmacy-system/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:prod": "turbo run build -- --mode production",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "test:e2e": "turbo run test:e2e",
    "test:watch": "turbo run test:watch",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules pnpm-lock.yaml",
    "clean:dist": "turbo run clean",
    "db:generate": "pnpm --filter @pharmacy/database exec pnpm db:generate:full",
    "db:generate:local": "pnpm --filter @pharmacy/database exec pnpm db:generate:local",
    "prisma:studio": "pnpm --filter @pharmacy/database exec prisma studio",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "dev:infra:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "dev:db:push": "pnpm --filter @pharmacy/server exec npx prisma db push --schema ../../packages/database/prisma/schema",
    "dev:db:seed": "pnpm --filter @pharmacy/server exec npx tsx prisma/seed.ts",
    "dev:db:setup": "pnpm dev:infra && pnpm dev:db:push && pnpm dev:db:seed",
    "dev:start": "pnpm --filter @pharmacy/server dev",
    "docker:build": "turbo run docker:build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "setup": "pnpm install && pnpm db:generate",
    "setup:dev": "pnpm setup && pnpm dev:db:setup",
    "setup:db": "pnpm docker:reset && pnpm prisma:migrate && pnpm prisma:seed",
    "analyze": "turbo run analyze",
    "analyze:bundle": "turbo run analyze:bundle",
    "precommit": "pnpm lint && pnpm typecheck",
    "prepush": "pnpm test && pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
